# Variables para el entorno labrodai (copiar a .env.local en el proyecto Vercel de lab)

# Supabase LAB (crear proyecto nuevo en supabase.com para labrodai)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO_LAB.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_lab
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_lab

# Auth
JWT_SECRET=rodai-lab-jwt-secret-2026

# API key que usa n8n para POST leads
CRM_API_KEY=rodai-lab-n8n-key-2026

# Entorno
NODE_ENV=development
